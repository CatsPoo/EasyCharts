DB_HOST=192.168.1.10
DB_PORT=5432
DB_USER=postgress
DB_PASS=postgress
DB_NAME=EasyCharts

DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=admin

JWT_SECRET=JWTKEY
JWT_EXPIRE_IN=30m

REFRESH_JWT_SECRET=JWTREFRESHKEY
REFRESH_JWT_EXPIRE_IN=1d

# Minimum log level to display. All levels at or above this severity will be shown.
# Severity order (low → high): verbose < debug < log < warn < error < fatal
# Example: LOG_LEVEL=warn  → shows warn, error, fatal
#          LOG_LEVEL=log   → shows log, warn, error, fatal  (default)
#          LOG_LEVEL=debug → shows debug, log, warn, error, fatal
LOG_LEVEL=log

# ── CORS (frontend origin allowed to call the backend) ───────────
# Set to your company domain to allow all subdomains (e.g. mycompany.com)
CORS_ALLOWED_DOMAINS=mycompany.com,otherwork.local
