# Docker Compose environment variables
# Copy this file to .env and fill in real values before running docker-compose up

# ── Database ─────────────────────────────────────────────────────
DB_USER=postgres
DB_PASS=postgres
DB_NAME=EasyCharts

# ── JWT Secrets (CHANGE THESE in production!) ────────────────────
JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRE_IN=30m

REFRESH_JWT_SECRET=change-me-to-a-different-long-random-secret
REFRESH_JWT_EXPIRE_IN=1d

# ── Default admin account (created on first boot) ────────────────
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=change-me-in-production

# ── CORS (frontend origin allowed to call the backend) ───────────
# Set to your company domain to allow all subdomains (e.g. mycompany.com)
CORS_ALLOWED_DOMAIN=mycompany.com

# ── Container registry images (used by Woodpecker CI) ────────────
BACKEND_IMAGE=registry.example.com/easycharts/backend
FRONTEND_IMAGE=registry.example.com/easycharts/frontend
